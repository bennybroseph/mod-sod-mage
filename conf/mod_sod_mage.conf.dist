########################################
# mod-sod-mage configuration
########################################
#
#    SodMage.Enable
#        Description: Master switch for the module. When disabled, all custom
#                     Mage spell behavior is skipped and the module is a no-op.
#        Default:     1 - (Enabled)
#                     0 - (Disabled)
#

SodMage.Enable = 1

#
#    SodMage.TemporalBeacon.ConversionPct
#        Description: Percent of the caster's Arcane spell damage converted to
#                     chronomantic healing on each Temporal Beacon target.
#        Default:     70
#

SodMage.TemporalBeacon.ConversionPct = 70

#
#    SodMage.TemporalBeacon.SelfPct
#        Description: Percent of the converted healing kept when the beacon
#                     target is the caster (i.e. a 50% reduction at 50).
#        Default:     50
#

SodMage.TemporalBeacon.SelfPct = 50

#
#    SodMage.TemporalBeacon.MultiTargetPct
#        Description: Percent of the converted healing kept when the Arcane
#                     damage came from a multi-target spell (80% reduction at 20).
#        Default:     20
#

SodMage.TemporalBeacon.MultiTargetPct = 20

#
#    SodMage.LivingFlame.SpeedPct
#        Description: Move speed of the Living Flame creature as a percent of
#                     normal run speed. Lower = the flame creeps more slowly
#                     toward its target.
#        Default:     40
#

SodMage.LivingFlame.SpeedPct = 40

#
#    SodMage.Enlightenment.HighManaPct
#        Description: Enlightenment grants +10% spell damage while the Mage is
#                     ABOVE this mana percentage. Strict threshold ("more than").
#        Default:     70
#

SodMage.Enlightenment.HighManaPct = 70

#
#    SodMage.Enlightenment.LowManaPct
#        Description: While BELOW this mana percentage, Enlightenment lets part of
#                     the Mage's mana regeneration continue through the Five Second
#                     Rule. Strict threshold ("below").
#        Default:     30
#

SodMage.Enlightenment.LowManaPct = 30

#
#    SodMage.Enlightenment.PollMs
#        Description: How often (ms) Enlightenment re-evaluates which mana state the
#                     Mage is in. SoD polls every 5000ms; lower values swap the buff
#                     faster as mana changes. Resolution is 1000ms (the passive's
#                     periodic tick).
#        Default:     5000
#

SodMage.Enlightenment.PollMs = 5000

#
#    SodMage.RewindTime.WindowSeconds
#        Description: Rewind Time looks back this many seconds: it heals the beaconed
#                     target for the damage they took within the window, and is
#                     ineffective unless your Temporal Beacon has been on them for at
#                     least this long ("had a Temporal Beacon 5 sec ago"). SoD is 5.
#        Default:     5
#

SodMage.RewindTime.WindowSeconds = 5

#
#    SodMage.LivingBomb.ScalingCapLevel
#        Description: Living Spark (the Living Bomb rune stand-in) stops scaling its
#                     explosion at this level, so it never out-scales the real Living
#                     Bomb. SoD Living Bomb is level 60.
#        Default:     60
#
#    SodMage.LivingBomb.FuseSeconds
#        Description: How long a planted Living Spark waits before it detonates (it does
#                     no damage and does not aggro until then). SoD Living Bomb is 12 sec.
#        Default:     12
#

SodMage.LivingBomb.ScalingCapLevel = 60
SodMage.LivingBomb.FuseSeconds = 12

#
#    Disguised-critter seeding (the Enlightenment acquisition event).
#    As real Elwynn Forest critters spawn, a share are converted in place into the
#    disguised "Polymorphed Apprentice". The originals are untouched in the DB and
#    return on respawn -- this only tunes how densely the disguised critters appear.
#    The chance scales with distance from a focal point (the Tower of Azora):
#    CritterChanceMaxPct within InnerRadius, falling off linearly to
#    CritterChanceMinPct at/beyond OuterRadius. Set both Max and Min to 0 to disable.
#
#    CritterChanceMaxPct  Default: 15   (chance near the focal point)
#    CritterChanceMinPct  Default: 5    (chance far away / elsewhere in Elwynn)
#    CritterCenterX/Y     Default: the Tower of Azora (-9528.949, -691.179), map 0
#    CritterInnerRadius   Default: 50   (full Max chance within this many yards)
#    CritterOuterRadius   Default: 600  (faded to Min chance beyond this)
#

SodMage.Enlightenment.CritterChanceMaxPct = 15
SodMage.Enlightenment.CritterChanceMinPct = 5
SodMage.Enlightenment.CritterCenterX = -9528.949
SodMage.Enlightenment.CritterCenterY = -691.179
SodMage.Enlightenment.CritterInnerRadius = 50
SodMage.Enlightenment.CritterOuterRadius = 600

#
#    SodMage.Drops.*NotesChance
#        Description: Percent chance for the rune-discovery "Spell Notes" to drop
#                     from their sources. The notes rows live in the *_unlock /
#                     mass_regeneration SQL; these keys tune their Chance, applied at
#                     startup and on `.reload config`. 0 disables that drop. When
#                     SodMage.Enable = 0 all three are forced to 0.
#        MassRegenNotesChance   Default: 100  (off the Awakened Lich, a summoned elite)
#        LivingFlameNotesChance Default: 20   (off leveling-zone trash)
#        RegenNotesChance       Default: 20   (off leveling-zone trash)
#

SodMage.Drops.MassRegenNotesChance = 100
SodMage.Drops.LivingFlameNotesChance = 20
SodMage.Drops.RegenNotesChance = 20
